# Enterprise RAG System - Environment Configuration
# Phase 1: Core Infrastructure
# Copy this file to .env and fill in the required values

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
# Options: development, staging, production

# ============================================================================
# POSTGRESQL CONFIGURATION
# ============================================================================
POSTGRES_DB=enterprise_rag
POSTGRES_USER=rag_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
# Generate strong password: openssl rand -base64 32
POSTGRES_PORT=5432

# Database connection pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ============================================================================
# MINIO (S3-COMPATIBLE OBJECT STORAGE)
# ============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
# Generate strong password: openssl rand -base64 32
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BROWSER_URL=https://minio.igwilo.com/9301
# For production: https://minio.yourdomain.com

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
# Generate strong password: openssl rand -base64 32
REDIS_PORT=6379
CACHE_TTL=300
# Cache TTL in seconds (5 minutes default)

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Canonical DB Agent API
CANONICAL_DB_API_PORT=8001

# Auth ACL Agent API
AUTH_ACL_API_PORT=8002

# API Workers (adjust based on CPU cores)
API_WORKERS=4
API_RELOAD=false
# Set to true only in development

# ============================================================================
# SECURITY
# ============================================================================
SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_KEY
# Generate: openssl rand -hex 32

# JWT Configuration
JWT_ALGORITHM=RS256
JWT_EXPIRATION=3600
# JWT expiration in seconds (1 hour default)

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://igwilo.com,https://api.igwilo.com

# ============================================================================
# OAUTH/OIDC CONFIGURATION
# ============================================================================
# Configure your OAuth2/OIDC provider (Okta, Auth0, Azure AD, Keycloak, etc.)
OIDC_PROVIDER_URL=https://auth.igwilo.com
# Example: https://dev-12345.okta.com/oauth2/default
# Example: https://your-tenant.auth0.com
# Example: https://login.microsoftonline.com/your-tenant-id/v2.0

OIDC_CLIENT_ID=your-client-id-here
OIDC_CLIENT_SECRET=your-client-secret-here

# OIDC Scopes (space-separated)
OIDC_SCOPES=openid profile email

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

LOG_FORMAT=json
# Options: json, text

# ============================================================================
# MONITORING (Optional for Phase 1)
# ============================================================================
# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PORT=9090

# OpenTelemetry tracing
TRACING_ENABLED=false
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# ============================================================================
# CLOUD DEPLOYMENT (Production)
# ============================================================================
# Domain configuration
DOMAIN=yourdomain.com
# Example: rag.company.com

# SSL/TLS
SSL_ENABLED=true
LETSENCRYPT_EMAIL=admin@yourdomain.com

# Nginx configuration
NGINX_CLIENT_MAX_BODY_SIZE=100M
# Maximum upload file size

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
# PostgreSQL backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
# Daily at 2 AM UTC (cron format)
BACKUP_RETENTION_DAYS=30

# MinIO backup
MINIO_BACKUP_ENABLED=true
MINIO_BACKUP_BUCKET=enterprise-rag-backups

# ============================================================================
# RESOURCE LIMITS (Docker)
# ============================================================================
# PostgreSQL
POSTGRES_MEMORY_LIMIT=4g
POSTGRES_CPU_LIMIT=2

# MinIO
MINIO_MEMORY_LIMIT=2g
MINIO_CPU_LIMIT=1

# Redis
REDIS_MEMORY_LIMIT=1g
REDIS_CPU_LIMIT=0.5

# API Services
API_MEMORY_LIMIT=1g
API_CPU_LIMIT=1

# ============================================================================
# DEVELOPMENT SETTINGS (Development only)
# ============================================================================
# Enable debug mode (DO NOT use in production)
DEBUG=false

# Enable API auto-reload (Development only)
API_RELOAD=false

# Enable SQL query logging (Development only)
SQL_ECHO=false

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features
FEATURE_DOCUMENT_INGESTION=true
FEATURE_VECTOR_SEARCH=false
# Will be enabled in Phase 3
FEATURE_BM25_SEARCH=false
# Will be enabled in Phase 3
FEATURE_KNOWLEDGE_GRAPH=false
# Will be enabled in Phase 3
FEATURE_ANSWER_GENERATION=false
# Will be enabled in Phase 5

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
# Requests per minute per user
RATE_LIMIT_BURST=10
# Burst allowance

# ============================================================================
# TENANT CONFIGURATION
# ============================================================================
# Default tenant settings
DEFAULT_TENANT_MAX_DOCUMENTS=10000
DEFAULT_TENANT_MAX_USERS=1000
DEFAULT_TENANT_MAX_STORAGE_GB=100

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit .env file to version control
# 2. Use strong, unique passwords for all services
# 3. Rotate secrets regularly in production
# 4. Use environment-specific .env files (.env.dev, .env.staging, .env.prod)
# 5. Consider using secret management tools (Vault, AWS Secrets Manager, etc.)
# 6. Review and update ALLOWED_ORIGINS for production deployment
# 7. Configure proper OIDC provider before deployment
# 8. Enable SSL/TLS for production deployment
# 9. Set up regular backups for PostgreSQL and MinIO
# 10. Monitor resource usage and adjust limits as needed